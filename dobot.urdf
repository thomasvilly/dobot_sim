<?xml version="1.0" encoding="utf-8"?>
<robot name="magician_isaac">

  <link name="magician_base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/dae/magicianBase.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision/core/magicianBase.dae"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.055"/>
      <mass value="1.0"/>
      <inertia ixx="0.001633" ixy="0" ixz="0" iyy="0.001633" iyz="0" izz="0.001250"/>
    </inertial>
  </link>

  <link name="magician_link_1">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/dae/magicianLink1.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision/core/magicianLink1.dae"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.06"/>
      <mass value="0.5"/>
      <inertia ixx="0.000750" ixy="0" ixz="0" iyy="0.000867" iyz="0" izz="0.000417"/>
    </inertial>
  </link>

  <joint name="magician_joint_1" type="revolute">
    <parent link="magician_base_link"/>
    <child link="magician_link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-2.35" upper="2.35" velocity="5.58"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="magician_link_2">
    <visual>
      <origin rpy="0 -0.349 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/dae/magicianLink2.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 -0.349 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/collision/core/magicianLink2.dae"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.067 0 0.05"/>
      <mass value="0.5"/>
      <inertia ixx="0.000156" ixy="0" ixz="0" iyy="0.000838" iyz="0" izz="0.000838"/>
    </inertial>
  </link>

  <joint name="magician_joint_2" type="revolute">
    <parent link="magician_link_1"/>
    <child link="magician_link_2"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-1.57" upper="1.57" velocity="5.58"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="magician_link_3">
    <visual>
      <origin rpy="0 -0.471 0" xyz="0.016 0 -0.134"/>
      <geometry>
        <mesh filename="meshes/dae/magicianLink3.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 -0.471 0" xyz="0.016 0 -0.134"/>
      <geometry>
        <mesh filename="meshes/collision/core/magicianLink3.dae"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.016 0 -0.134"/>
      <mass value="0.5"/>
      <inertia ixx="0.000121" ixy="0" ixz="0" iyy="0.001127" iyz="0" izz="0.001127"/>
    </inertial>
  </link>

  <joint name="magician_joint_3" type="revolute">
    <parent link="magician_link_2"/>
    <child link="magician_link_3"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-1.57" upper="1.22" velocity="5.58"/>
    <origin rpy="0 0 0" xyz="0 0 0.135"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="magician_joint_end_pitch" type="revolute">
    <parent link="magician_link_3"/>
    <child link="magician_link_4"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="5.58"/>
    <origin rpy="0 0 0" xyz="0.147 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="magician_link_4">
    <visual>
      <origin rpy="0 0 0" xyz="-0.177 0 -0.058"/>
      <geometry>
        <mesh filename="meshes/dae/magicianLink4.dae"/>
      </geometry>
    </visual>
    <collision>
