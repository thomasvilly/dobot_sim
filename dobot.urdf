    <inertial>
      <origin rpy="0 0 0" xyz="-0.237 0 -0.058"/>
      <mass value="0.05"/>
      <inertia ixx="0.000010" ixy="0" ixz="0" iyy="0.000020" iyz="0" izz="0.000020"/>
