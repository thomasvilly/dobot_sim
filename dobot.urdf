    <inertial>
      <origin rpy="0 0 0" xyz="-0.177 0 -0.058"/>
      <mass value="0.2"/>
      <inertia ixx="0.000068" ixy="0" ixz="0" iyy="0.000133" iyz="0" izz="0.000148"/>
    </inertial>
  </link>

  <link name="magician_end_effector">
    <visual>
      <origin rpy="0 0 0" xyz="-0.237 0 -0.058"/>
      <geometry>
        <mesh filename="meshes/dae/magicianSuctionCup.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.237 0 -0.058"/>
      <geometry>
        <mesh filename="meshes/collision/end_tools/suction_cup_collision_part1.dae"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="-0.237 0 -0.058"/>
      <geometry>
        <mesh filename="meshes/collision/end_tools/suction_cup_collision_part2.dae"/>
